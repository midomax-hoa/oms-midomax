# =========================================================================
# GLOBAL MONOREPO ENVIRONMENT VARIABLES
# =========================================================================

# -------------------------------------------------------------------------
# apps/web — Vite frontend
# -------------------------------------------------------------------------
VITE_API_URL=/api
VITE_SHOPEE_API_URL=/api

# -------------------------------------------------------------------------
# apps/api — NestJS backend
# -------------------------------------------------------------------------

# Shopee Partner App credentials
# Lấy từ Shopee Partner Console: https://partner.shopeemobile.com
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=

# Shopee API host
# Production: https://partner.shopeemobile.com
# Sandbox:    https://partner.test-stable.shopeemobile.com
SHOPEE_API_HOST=https://partner.test-stable.shopeemobile.com

# URL Shopee sẽ redirect về sau khi shop authorize
# Phải khớp CHÍNH XÁC với giá trị đã đăng ký trong Shopee Partner Console
SHOPEE_REDIRECT_URL=https://oms.midomax.vn/api/shopee/callback

# URL frontend để redirect sau khi callback thành công
# Dev: http://localhost:3000
# Production: https://oms.midomax.vn
SHOPEE_FRONTEND_URL=http://localhost:3000

# Port cho NestJS API server
API_PORT=3002

# -------------------------------------------------------------------------
# Lazada Partner App credentials
# -------------------------------------------------------------------------
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
LAZADA_API_HOST=https://api.lazada.vn/rest
LAZADA_REDIRECT_URL=http://localhost:3000/api/lazada/callback
LAZADA_FRONTEND_URL=http://localhost:3000

# -------------------------------------------------------------------------
# Global environment
# -------------------------------------------------------------------------
DOMAIN=oms.midomax.vn
NODE_ENV=development
